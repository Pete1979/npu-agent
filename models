#!/bin/bash
# List and manage local NPU models via Lemonade
# Usage: ./models [list|installed|pull|remove]

LEMONADE_DIR="${LEMONADE_DIR:-$HOME/projects/private/local-llm/lemonade/lemonade-embeddable-10.2.0-ubuntu-x64}"
LEMONADE="$LEMONADE_DIR/lemonade"

case "$1" in
    list|"")
        echo "NPU (FLM) models in the catalog:"
        "$LEMONADE" list 2>/dev/null | grep -iE 'FLM|Model' 
        ;;
    installed)
        echo "Pulled models:"
        "$LEMONADE" list 2>/dev/null | awk 'NR==1 || $2=="Yes"'
        ;;
    pull)
        MODEL="$2"
        [ -z "$MODEL" ] && read -p "Enter model name to download (e.g. qwen3-8b-FLM): " MODEL
        "$LEMONADE" pull "$MODEL"
        ;;
    remove)
        MODEL="$2"
        [ -z "$MODEL" ] && read -p "Enter model name to remove: " MODEL
        "$LEMONADE" delete "$MODEL"
        ;;
    *)
        echo "Usage: $0 [list|installed|pull <name>|remove <name>]"
        echo "  list       - Show NPU/FLM catalog (default)"
        echo "  installed  - Show already-downloaded models"
        echo "  pull       - Download a model"
        echo "  remove     - Delete a downloaded model"
        ;;
esac
